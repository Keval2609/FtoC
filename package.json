{
  "name": "terradirect",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:demo": "vite --mode demo",
    "build": "vite build",
    "build:demo": "vite build --mode demo",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "preview:demo": "vite preview --outDir dist-demo",
    "preview:production": "vite preview --outDir dist-prod",
    "deploy:demo": "npm run build:demo && firebase deploy --only hosting:demo -P demo",
    "deploy:production": "npm run build:production && firebase deploy --only hosting:marketplace -P default"
  },
  "dependencies": {
    "firebase": "^11.10.0",
    "framer-motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.0"
  }
}
